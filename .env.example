# ═══════════════════════════════════════════════════════════════════════════
# SSI Endoskeleton — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ═══════════════════════════════════════════════════════════════════════════

# === PFLICHT (Required) ===
SITE_NAME="Firmenname"
SITE_EMAIL="office@example.at"
SITE_URL="https://example.at"

# === KONTAKTFORMULAR ===
# CC-Adresse für Kontaktformular-Mails (optional)
CONTACT_CC=""

# === E-MAIL (SMTP) ===
# Wird von contact.php verwendet
SMTP_HOST="smtp.example.at"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.at"

# === GOOGLE MAPS (optional — leer = Modul inaktiv) ===
GOOGLE_MAPS_KEY=""

# === GOOGLE ANALYTICS (optional — leer = Modul inaktiv) ===
GOOGLE_ANALYTICS_ID=""

# === RECAPTCHA (optional — leer = kein Captcha) ===
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# === NEWSLETTER (optional — leer = Modul inaktiv) ===
NEWSLETTER_API_URL=""
NEWSLETTER_API_KEY=""
